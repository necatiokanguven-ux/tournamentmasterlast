{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs && esbuild src/server/watchdog/watchdogServer.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/watchdog.cjs",
    "start": "node dist/server.cjs",
    "start:watchdog": "node dist/watchdog.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "import:json-to-pg": "tsx scripts/import-json-to-pg.ts",
    "load-test:zones": "tsx scripts/load-test-zones.ts",
    "load-test:dealers": "tsx scripts/load-test-dealers.ts",
    "verify:runtime": "powershell -NoProfile -ExecutionPolicy Bypass -File packaging/scripts/verify-runtime.ps1 -InstallDir packaging",
    "stage:runtime": "powershell -NoProfile -ExecutionPolicy Bypass -File packaging/scripts/stage-runtime.ps1 -DownloadNode -SkipIfPresent",
    "start:pm2": "pm2 start ecosystem.config.cjs --update-env && pm2 save",
    "stop:pm2": "pm2 stop tournament-master tournament-master-watchdog",
    "restart:pm2": "pm2 restart tournament-master",
    "package:test-win": "powershell -NoProfile -ExecutionPolicy Bypass -File packaging/build-test-package.ps1",
    "build:package:win": "powershell -NoProfile -ExecutionPolicy Bypass -File packaging/installer/build-installer.ps1",
    "build:package:mac": "powershell -NoProfile -ExecutionPolicy Bypass -File packaging/build-package-mac.ps1",
    "build:package:mac:dmg": "bash packaging/mac/build-dmg.sh",
    "build:package:mac:dmg:vps": "powershell -NoProfile -ExecutionPolicy Bypass -File packaging/mac/build-dmg-vps.ps1",
    "vps:id-scan": "npm --prefix vps/id-scan run start",
    "vps:id-scan:dev": "npm --prefix vps/id-scan run dev",
    "build:packages": "powershell -NoProfile -ExecutionPolicy Bypass -File packaging/build-packages.ps1",
    "test:system-health": "packaging\\test-system-health.bat",
    "build:installer": "powershell -NoProfile -ExecutionPolicy Bypass -File packaging/installer/build-installer.ps1",
    "build:installer:full": "powershell -NoProfile -ExecutionPolicy Bypass -File packaging/installer/build-installer.ps1 -TryInstallInno",
    "install:inno": "powershell -NoProfile -ExecutionPolicy Bypass -File packaging/installer/install-inno-setup.ps1"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.22.0",
    "pm2": "^6.0.14",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "semver": "^7.8.5",
    "vite": "^6.2.3",
    "ws": "^8.21.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
